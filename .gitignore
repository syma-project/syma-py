.claude/

# gui (Tauri frontend, deprecated)
gui/node_modules/
gui/dist/
gui/src-tauri/target/

# nb (notebook frontend)
nb/node_modules/
nb/dist/

# notebook (WLJS fork, deprecated)
notebook/node_modules/
